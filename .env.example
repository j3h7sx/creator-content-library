# Optional. Without this key, cataloging falls back to filename/basic metadata search.
OPENAI_API_KEY=

# Optional model overrides. Keep these configurable because model availability changes over time.
OPENAI_CATALOG_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional Pinterest downloader wrapper.
# This is not an official Pinterest API integration.
# Example:
# PINTEREST_DOWNLOADER_COMMAND=python3
# PINTEREST_DOWNLOADER_ARGS=/absolute/path/to/downloader.py {url} --out {out}
PINTEREST_DOWNLOADER_COMMAND=
PINTEREST_DOWNLOADER_ARGS=
