{
  "name": "creator-content-library",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first visual asset library for creators, marketers, and app builders.",
  "type": "module",
  "packageManager": "bun@1.2.0",
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "catalog": "node --import tsx scripts/catalog.ts",
    "search": "node --import tsx scripts/search.ts",
    "rebuild": "node --import tsx scripts/rebuild.ts",
    "dedupe": "node --import tsx scripts/dedupe.ts",
    "pinterest:board": "node --import tsx scripts/download-pinterest-board.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "latest",
    "@radix-ui/react-select": "latest",
    "@radix-ui/react-separator": "latest",
    "@radix-ui/react-slot": "latest",
    "@radix-ui/react-tooltip": "latest",
    "better-sqlite3": "latest",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "commander": "latest",
    "lucide-react": "latest",
    "next": "latest",
    "openai": "latest",
    "react": "latest",
    "react-dom": "latest",
    "sharp": "latest",
    "tailwind-merge": "latest",
    "tailwindcss-animate": "latest"
  },
  "devDependencies": {
    "@eslint/eslintrc": "latest",
    "@types/better-sqlite3": "latest",
    "@types/bun": "^1.3.14",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "latest",
    "eslint": "9.39.1",
    "eslint-config-next": "latest",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "latest",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.3",
    "typescript": "latest",
    "typescript-eslint": "^8.59.4"
  }
