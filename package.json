{
  "name": "creator-content-library",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first visual asset library for creators, marketers, and app builders.",
  "type": "module",
  "packageManager": "bun@1.2.0",
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "catalog": "node --import tsx scripts/catalog.ts",
    "search": "node --import tsx scripts/search.ts",
    "rebuild": "node --import tsx scripts/rebuild.ts",
    "dedupe": "node --import tsx scripts/dedupe.ts",
    "pinterest:board": "node --import tsx scripts/download-pinterest-board.ts",
    "pinterest:setup": "python3 -m venv .venv-pinterest && .venv-pinterest/bin/python -m pip install -r vendor/pinterest-downloader/requirements.txt"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "latest",
    "@radix-ui/react-select": "latest",
    "@radix-ui/react-separator": "latest",
    "@radix-ui/react-slot": "latest",
    "@radix-ui/react-tooltip": "latest",
    "better-sqlite3": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "latest",
    "lucide-react": "^1.16.0",
    "next": "latest",
    "openai": "latest",
    "radix-ui": "^1.4.3",
    "react": "latest",
    "react-dom": "latest",
    "shadcn": "^4.7.0",
    "sharp": "latest",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "latest",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/better-sqlite3": "latest",
    "@types/bun": "^1.3.14",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "9.39.1",
    "eslint-config-next": "latest",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "latest",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "latest",
    "typescript-eslint": "^8.59.4"
  }
}
